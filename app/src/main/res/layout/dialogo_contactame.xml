<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/dialogoredondeado_contactame">
    <androidx.cardview.widget.CardView
        android:layout_margin="1.5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        tools:ignore="UselessParent"
        app:cardCornerRadius="15.5dp"
        app:cardElevation="3dp">
        <LinearLayout
            android:id="@+id/hCardViewDialog"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="#4DA6B6"
                android:contentDescription="@string/descripcion_imagen_dialog"
                android:scaleType="centerCrop"
                android:src="@drawable/robertozapata" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/subTitle_name"
                app:boxStrokeWidth="0dp"
                app:hintTextColor="@color/text_secondary_fondo_blanco"
                app:boxStrokeColor="@color/white">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/TIETdialog_docNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/text_tipodeatencion"
                    android:enabled="false"
                    android:backgroundTint="#00FFFFFF"
                    android:textColor="@color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:id="@+id/text_dialog"
                android:gravity="start"
                android:textSize="14sp"
                android:textColor="@color/text_secondary_fondo_blanco"
                android:text="@string/text_dialog_contactame"
                android:paddingStart="5dp"
                android:paddingEnd="5dp" />
            <LinearLayout
                android:id="@+id/LLContactoDocDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="5dp"
                android:paddingEnd="5dp">
                <pl.droidsonroids.gif.GifImageButton
                    android:id="@+id/iconLlamarDocDialog"
                    android:layout_width="40dp"
                    android:layout_height="32dp"
                    android:padding="0dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/phoneringdoc"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="10dp" />
                <ImageButton
                    android:contentDescription="@string/img_facebook"
                    android:id="@+id/iconFacebookDocDialog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/ic_facebookoriginal"/>
                <ImageButton
                    android:contentDescription="@string/img_instagram"
                    android:id="@+id/iconInstagramDocDialog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/ic_instagramoriginal"/>
            </LinearLayout>
            <Button
                android:layout_gravity="end"
                android:id="@+id/btn_dialogo_ok"
                android:layout_width="70dp"
                android:layout_height="38dp"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginEnd="15dp"
                android:text="@string/btn_dialog_cerrar"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.TextButton.Dialog.Flush"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>